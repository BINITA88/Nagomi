# Copy this file to ".env" and fill in real values.

# Port the API/admin server listens on
PORT=4000

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/nagomi
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/nagomi?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/nagomi

# Admin panel login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Secret used to sign admin login tokens (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret-string

# Comma-separated list of origins allowed to call the API from the browser.
# Include your Vercel site URL here. Use * to allow all (dev only).
CORS_ORIGINS=*

# Public base URL of THIS server, used to build absolute image URLs.
# e.g. https://nagomi-api.onrender.com  (leave blank for local dev)
PUBLIC_BASE_URL=
